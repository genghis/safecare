# Database
DATABASE_URL=postgres://safecare:safecare@localhost:5432/safecare

# Redis
REDIS_URL=redis://localhost:6379

# Security (generate with: openssl rand -hex 32)
JWT_SECRET=
DEK=
HMAC_KEY=

# Twilio (optional — only needed for SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# WhatsApp (via Baileys — pair from the dashboard, no config needed)
# Auth state is persisted in this directory (default: /app/whatsapp-auth)
# WHATSAPP_AUTH_DIR=/app/whatsapp-auth

# JotForm (optional)
JOTFORM_API_KEY=

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:3001
